; this assignment was done individually, and resubmitted to be more consise.

0 _ _ * halt-reject
0 # # * halt-reject
0 0 0 r x0_only
0 1 1 r x_scan

; x begins with 0 => x must be exactly "0" then '#'
x0_only # # r y_start
x0_only 0 0 * halt-reject
x0_only 1 1 * halt-reject
x0_only _ _ * halt-reject

; x begins with 1 => scan until '#'
x_scan 0 0 r x_scan
x_scan 1 1 r x_scan
x_scan # # r y_start
x_scan _ _ * halt-reject

; y must exist, must not start with '#', and must be valid
y_start _ _ * halt-reject
y_start # # * halt-reject
y_start 0 0 r y0_only
y_start 1 1 r y_scan

; y begins with 0 => y must be exactly "0" and then blank
y0_only _ _ l rewind
y0_only 0 0 * halt-reject
y0_only 1 1 * halt-reject
y0_only # # * halt-reject

; y begins with 1 => scan to blank, no extra '#'
y_scan 0 0 r y_scan
y_scan 1 1 r y_scan
y_scan # # * halt-reject
y_scan _ _ l rewind

rewind 0 0 l rewind
rewind 1 1 l rewind
rewind # # l rewind
rewind A A l rewind
rewind B B l rewind
rewind C C l rewind
rewind D D l rewind
rewind E E l rewind
rewind F F l rewind
rewind G G l rewind
rewind H H l rewind
rewind _ _ r len_round

; find next unmarked bit in x
len_round A A r len_round
len_round B B r len_round
len_round 0 A r go_hash_from_x
len_round 1 B r go_hash_from_x
len_round # # r x_done_check_y   ; x has no more bits

; move to '#'
go_hash_from_x 0 0 r go_hash_from_x
go_hash_from_x 1 1 r go_hash_from_x
go_hash_from_x A A r go_hash_from_x
go_hash_from_x B B r go_hash_from_x
go_hash_from_x # # r mark_y_bit
go_hash_from_x _ _ * halt-reject

; mark next unmarked bit in y; if none => y exhausted => ACCEPT
mark_y_bit C C r mark_y_bit
mark_y_bit D D r mark_y_bit
mark_y_bit 0 C l back_left
mark_y_bit 1 D l back_left
mark_y_bit _ _ * halt-accept
mark_y_bit # # * halt-reject

; x exhausted: check whether y has any unmarked bits left
x_done_check_y C C r x_done_check_y
x_done_check_y D D r x_done_check_y
x_done_check_y 0 0 * halt-reject
x_done_check_y 1 1 * halt-reject
x_done_check_y # # * halt-reject
x_done_check_y _ _ l restore_rewind

; return to left end for next length round
back_left 0 0 l back_left
back_left 1 1 l back_left
back_left # # l back_left
back_left A A l back_left
back_left B B l back_left
back_left C C l back_left
back_left D D l back_left
back_left _ _ r len_round

restore_rewind 0 0 l restore_rewind
restore_rewind 1 1 l restore_rewind
restore_rewind # # l restore_rewind
restore_rewind A A l restore_rewind
restore_rewind B B l restore_rewind
restore_rewind C C l restore_rewind
restore_rewind D D l restore_rewind
restore_rewind _ _ r restore_scan

restore_scan A 0 r restore_scan
restore_scan B 1 r restore_scan
restore_scan C 0 r restore_scan
restore_scan D 1 r restore_scan
restore_scan 0 0 r restore_scan
restore_scan 1 1 r restore_scan
restore_scan # # r restore_scan
restore_scan _ _ l lex_rewind

lex_rewind 0 0 l lex_rewind
lex_rewind 1 1 l lex_rewind
lex_rewind # # l lex_rewind
lex_rewind _ _ r lex_x

lex_x E E r lex_x
lex_x F F r lex_x
lex_x 0 E r lex_go_hash0
lex_x 1 F r lex_go_hash1
lex_x # # * halt-accept

lex_go_hash0 0 0 r lex_go_hash0
lex_go_hash0 1 1 r lex_go_hash0
lex_go_hash0 E E r lex_go_hash0
lex_go_hash0 F F r lex_go_hash0
lex_go_hash0 # # r lex_y0
lex_go_hash0 _ _ * halt-reject

lex_go_hash1 0 0 r lex_go_hash1
lex_go_hash1 1 1 r lex_go_hash1
lex_go_hash1 E E r lex_go_hash1
lex_go_hash1 F F r lex_go_hash1
lex_go_hash1 # # r lex_y1
lex_go_hash1 _ _ * halt-reject

; in y: skip processed, compare
lex_y0 G G r lex_y0
lex_y0 H H r lex_y0
lex_y0 0 G l lex_back
lex_y0 1 H * halt-reject
lex_y0 _ _ * halt-reject
lex_y0 # # * halt-reject

lex_y1 G G r lex_y1
lex_y1 H H r lex_y1
lex_y1 0 G * halt-accept
lex_y1 1 H l lex_back
lex_y1 _ _ * halt-reject
lex_y1 # # * halt-reject

lex_back 0 0 l lex_back
lex_back 1 1 l lex_back
lex_back # # l lex_back
lex_back E E l lex_back
lex_back F F l lex_back
lex_back G G l lex_back
lex_back H H l lex_back
lex_back _ _ r lex_x
